                                            <td class="text-dark">@emp.ApellidoPaterno</td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-sm btn-success px-3 rounded-pill shadow-sm" 
                                                        @onclick="() => SeleccionarEmpleado(emp)">
