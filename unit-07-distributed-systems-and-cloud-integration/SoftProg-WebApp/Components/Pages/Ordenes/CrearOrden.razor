                </div>
                <div class="modal-footer bg-light py-2">
                    <button type="button" class="btn btn-secondary px-4 shadow-sm" @onclick="CerrarModalEmpleado">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private OrdenVenta nuevaOrden = new OrdenVenta() { FechaHora = DateTime.Now };
    
    // Lista de todos los productos y productos filtrados
    private List<Producto> todosLosProductos = new();
    private List<Producto> productosFiltrados = new();
    
    // Variables para el control del Modal de Productos
    private bool mostrarModal = false;
    private string textoBusqueda = "";
    private LineaOrdenVenta? lineaActiva;

    // Variables para el control del Modal de Clientes
    private bool mostrarModalCliente = false;
    private string textoBusquedaCliente = "";
    private List<Cliente> todosLosClientes = new();
    private List<Cliente> clientesFiltrados = new();

    // Variables para el control del Modal de Empleados
    private bool mostrarModalEmpleado = false;
    private string textoBusquedaEmpleado = "";
    private List<Empleado> todosLosEmpleados = new();
    private List<Empleado> empleadosFiltrados = new();

    protected override void OnInitialized()
    {
        todosLosProductos = Producto.ObtenerProductosEstaticos();
        productosFiltrados = new List<Producto>(todosLosProductos);
        
        todosLosClientes = Cliente.ObtenerClientesEstaticos();
        clientesFiltrados = new List<Cliente>(todosLosClientes);

        todosLosEmpleados = Empleado.ObtenerEmpleadosEstaticos();
        empleadosFiltrados = new List<Empleado>(todosLosEmpleados);
        
        // Inicializar la orden con una primera línea vacía para facilitar la interacción
        AgregarLinea();
    }

    private void AgregarLinea()
    {
        int siguienteNumeroLinea = nuevaOrden.Lineas.Any() ? nuevaOrden.Lineas.Max(l => l.NumeroLinea) + 1 : 1;
        
        nuevaOrden.Lineas.Add(new LineaOrdenVenta
        {
            NumeroLinea = siguienteNumeroLinea,
            Cantidad = 1,
            PrecioUnitario = 0.00m
        });
        
        RecalcularTotal();
    }

    private void EliminarLinea(LineaOrdenVenta linea)
    {
        nuevaOrden.Lineas.Remove(linea);
        
        // Reordenar los números de línea correlativos
        int correlativo = 1;
        foreach (var l in nuevaOrden.Lineas)
        {
            l.NumeroLinea = correlativo++;
        }
        
        RecalcularTotal();
    }

    private void RecalcularTotal()
    {
        nuevaOrden.MontoTotal = nuevaOrden.Lineas.Sum(l => l.Subtotal);
    }

    private void ActualizarCantidad(LineaOrdenVenta line, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int cant) && cant > 0)
        {
            line.Cantidad = cant;
        }
        else
        {
            line.Cantidad = 1;
        }
        RecalcularTotal();
    }

    private void AbrirBuscadorProducto(LineaOrdenVenta line)
    {
        lineaActiva = line;
        textoBusqueda = "";
        productosFiltrados = new List<Producto>(todosLosProductos);
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        lineaActiva = null;
    }

    private void FiltrarProductos()
    {
        if (string.IsNullOrWhiteSpace(textoBusqueda))
        {
            productosFiltrados = new List<Producto>(todosLosProductos);
        }
        else
        {
            productosFiltrados = todosLosProductos
                .Where(p => p.Nombre.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void SeleccionarProducto(Producto producto)
    {
        if (lineaActiva != null)
        {
            lineaActiva.Producto = producto;
            lineaActiva.PrecioUnitario = producto.PrecioUnitario;
            
            RecalcularTotal();
            CerrarModal();
        }
    }

    // Buscador de Clientes
    private void AbrirBuscadorCliente()
    {
        textoBusquedaCliente = "";
        clientesFiltrados = new List<Cliente>(todosLosClientes);
        mostrarModalCliente = true;
    }

    private void CerrarModalCliente()
    {
        mostrarModalCliente = false;
    }

    private void FiltrarClientes()
    {
        if (string.IsNullOrWhiteSpace(textoBusquedaCliente))
        {
            clientesFiltrados = new List<Cliente>(todosLosClientes);
        }
        else
        {
            clientesFiltrados = todosLosClientes
                .Where(c => c.Nombre.Contains(textoBusquedaCliente, StringComparison.OrdinalIgnoreCase)
                         || c.ApellidoPaterno.Contains(textoBusquedaCliente, StringComparison.OrdinalIgnoreCase)
                         || c.DNI.Contains(textoBusquedaCliente, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void SeleccionarCliente(Cliente cliente)
    {
        nuevaOrden.Cliente = cliente;
        CerrarModalCliente();
    }

    // Buscador de Empleados
    private void AbrirBuscadorEmpleado()
    {
        textoBusquedaEmpleado = "";
        empleadosFiltrados = new List<Empleado>(todosLosEmpleados);
        mostrarModalEmpleado = true;
    }

    private void CerrarModalEmpleado()
    {
        mostrarModalEmpleado = false;
    }

    private void FiltrarEmpleados()
    {
        if (string.IsNullOrWhiteSpace(textoBusquedaEmpleado))
        {
            empleadosFiltrados = new List<Empleado>(todosLosEmpleados);
        }
        else
        {
            empleadosFiltrados = todosLosEmpleados
                .Where(e => e.Nombre.Contains(textoBusquedaEmpleado, StringComparison.OrdinalIgnoreCase)
                         || e.ApellidoPaterno.Contains(textoBusquedaEmpleado, StringComparison.OrdinalIgnoreCase)
                         || e.DNI.Contains(textoBusquedaEmpleado, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void SeleccionarEmpleado(Empleado empleado)
    {
        nuevaOrden.Empleado = empleado;
        CerrarModalEmpleado();
    }

    private void GuardarOrden()
    {
        // Solo guardamos si hay líneas, todas tienen un producto seleccionado, y se seleccionó Cliente y Empleado
        if (nuevaOrden.Lineas.Any() 
            && !nuevaOrden.Lineas.Any(l => l.Producto == null)
            && nuevaOrden.Cliente != null
            && nuevaOrden.Empleado != null)
        {
            OrdenVenta.AgregarOrden(nuevaOrden);
            NavigationManager.NavigateTo("/administrar-ordenes");
        }
    }
}
